generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── AUTH / TENANTS ──

model Tenant {
  id                  String   @id @default(cuid())
  customerCode        String   @unique
  name                String
  username            String   @unique
  email               String   @unique
  passwordHash        String
  role                String   @default("customer_admin")
  language            String   @default("en")
  timezone            String   @default("Asia/Kolkata")
  logoUrl             String?
  isActive            Boolean  @default(true)
  mfaEnabled          Boolean  @default(false)
  sessionsValidAfter  DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subscription  Subscription?
  sites         Site[]
  users         User[]
  findings      Finding[]
  capas         CAPA[]
  deviations    Deviation[]
  fda483Events  FDA483Event[]
  systems       GxPSystem[]
  documents       Document[]
  raidItems       RAIDItem[]
  auditLogs       AuditLog[]
  inspections     Inspection[]
  playbooks       Playbook[]
  trainingRecords TrainingRecord[]
}

model Subscription {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  maxAccounts Int      @default(5)
  startDate   DateTime
  expiryDate  DateTime
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── SETTINGS ──

model Site {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  location  String?
  gmpScope  String?
  risk      String   @default("MEDIUM")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users      User[]
  findings   Finding[]
  capas      CAPA[]
  deviations Deviation[]

  @@unique([tenantId, name])
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  siteId       String?
  name         String
  email        String
  username     String
  passwordHash String
  role         String
  gxpSignatory Boolean   @default(false)
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site   Site?  @relation(fields: [siteId], references: [id])

  @@unique([tenantId, email])
  @@unique([tenantId, username])
}

// ── GAP ASSESSMENT ──

model Finding {
  id           String    @id @default(cuid())
  tenantId     String
  siteId       String?
  requirement  String
  area         String
  framework    String?
  severity     String
  status       String    @default("Open")
  owner        String
  targetDate   DateTime?
  rootCause    String?
  evidenceLink String?
  linkedCAPAId String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site   Site?  @relation(fields: [siteId], references: [id])
  capa   CAPA?
}

// ── CAPA ──

model CAPA {
  id                 String    @id @default(cuid())
  // Human-readable per-tenant identifier, e.g. "CAPA-2026-014".
  // Nullable for the migration-then-backfill window; populated for every
  // row by the post-migration backfill, and for new rows by createCAPA's
  // sequence-allocating transaction. Uniqueness is enforced globally
  // (rather than per-tenant) because the cross-tenant collision space is
  // tiny — a tenant rarely creates >999 CAPAs in a year — and a global
  // unique index is cheaper to enforce in SQLite than a composite one.
  reference          String?   @unique
  tenantId           String
  siteId             String?
  findingId          String?   @unique
  source             String
  description        String
  risk               String
  owner              String
  dueDate            DateTime?
  status             String    @default("Open")
  rca                String?
  rcaMethod          String?
  correctiveActions  String?
  effectivenessCheck Boolean   @default(false)
  effectivenessDate  DateTime?
  diGate             Boolean   @default(false)
  diGateStatus       String?
  diGateNotes        String?
  diGateReviewedBy   String?
  diGateReviewDate   DateTime?
  closedBy           String?
  closedAt           DateTime?
  createdBy          String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site           Site?          @relation(fields: [siteId], references: [id])
  finding        Finding?       @relation(fields: [findingId], references: [id])
  documents      CAPADocument[]
  evidenceItems  EvidenceItem[]
}

model CAPADocument {
  id          String    @id @default(cuid())
  capaId      String
  fileName    String
  fileSize    String?
  fileType    String?
  version     String    @default("v1.0")
  status      String    @default("current")
  uploadedBy  String
  approvedBy  String?
  approvedAt  DateTime?
  description String?
  createdAt   DateTime  @default(now())

  capa CAPA @relation(fields: [capaId], references: [id], onDelete: Cascade)
}

// ── DEVIATION ──

model Deviation {
  id                   String    @id @default(cuid())
  tenantId             String
  siteId               String?
  title                String
  description          String
  type                 String
  category             String
  severity             String
  area                 String
  detectedBy           String
  detectedDate         DateTime
  owner                String
  dueDate              DateTime?
  status               String    @default("open")
  immediateAction      String?
  rootCause            String?
  rcaMethod            String?
  patientSafetyImpact  String?
  productQualityImpact String?
  regulatoryImpact     String?
  batchesAffected      String?
  linkedCAPAId         String?
  closedBy             String?
  closedDate           DateTime?
  closureNotes         String?
  createdBy            String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site   Site?  @relation(fields: [siteId], references: [id])
}

// ── FDA 483 ──

model FDA483Event {
  id               String    @id @default(cuid())
  tenantId         String
  referenceNumber  String
  eventType        String
  agency           String
  siteId           String
  inspectionDate   DateTime
  responseDeadline DateTime
  status           String    @default("Open")
  responseDraft    String?
  agiDraft         String?
  submittedAt      DateTime?
  submittedBy      String?
  signatureMeaning String?
  closedAt         DateTime?
  createdBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  observations FDA483Observation[]
  commitments  FDA483Commitment[]
  documents    FDA483Document[]
}

model FDA483Document {
  id         String   @id @default(cuid())
  eventId    String
  fileName   String
  fileUrl    String
  fileType   String?
  fileSize   String?
  type       String   @default("response")
  uploadedBy String
  createdAt  DateTime @default(now())

  event FDA483Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model FDA483Observation {
  id           String   @id @default(cuid())
  eventId      String
  number       Int
  text         String
  severity     String
  area         String?
  regulation   String?
  rcaMethod    String?
  rootCause    String?
  capaId       String?
  responseText String?
  status       String   @default("Open")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event FDA483Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model FDA483Commitment {
  id      String    @id @default(cuid())
  eventId String
  text    String
  dueDate DateTime?
  owner   String?
  status  String    @default("Pending")

  event FDA483Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ── CSV/CSA ──

model GxPSystem {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  type             String
  vendor           String?
  version          String?
  gxpRelevance     String   @default("Major")
  part11Status     String   @default("N/A")
  annex11Status    String   @default("N/A")
  gamp5Category    String   @default("4")
  validationStatus String   @default("Not Started")
  riskLevel        String   @default("MEDIUM")
  siteId           String?
  intendedUse      String?
  gxpScope         String?
  plannedActions   String?
  owner            String?
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  validationStages  ValidationStage[]
  rtmEntries        RTMEntry[]
  roadmapActivities RoadmapActivity[]
}

model ValidationStage {
  id              String    @id @default(cuid())
  systemId        String
  stageName       String
  status          String    @default("not_started")
  notes           String?
  submittedBy     String?
  submittedDate   DateTime?
  approvedBy      String?
  approvedDate    DateTime?
  rejectedBy      String?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  system GxPSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

model RTMEntry {
  id                 String   @id @default(cuid())
  systemId           String
  ursId              String
  ursRequirement     String
  ursRegulation      String?
  ursPriority        String   @default("high")
  fsReference        String?
  fsStatus           String   @default("missing")
  dsReference        String?
  dsStatus           String   @default("na")
  iqTestId           String?
  iqResult           String?
  oqTestId           String?
  oqResult           String?
  pqTestId           String?
  pqResult           String?
  evidenceStatus     String   @default("missing")
  traceabilityStatus String   @default("broken")
  linkedFindingId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  system GxPSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

model RoadmapActivity {
  id             String    @id @default(cuid())
  systemId       String
  title          String
  type           String
  status         String    @default("Planned")
  startDate      DateTime?
  endDate        DateTime?
  owner          String?
  completionType String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  system GxPSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

// ── EVIDENCE ──

model Document {
  id             String    @id @default(cuid())
  tenantId       String
  fileName       String
  fileType       String?
  fileSize       String?
  version        String    @default("v1.0")
  status         String    @default("draft")
  description    String?
  linkedModule   String?
  linkedRecordId String?
  uploadedBy     String
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── GOVERNANCE ──

model RAIDItem {
  id           String    @id @default(cuid())
  tenantId     String
  type         String
  title        String
  description  String
  priority     String
  owner        String
  dueDate      DateTime?
  status       String    @default("Open")
  impact       String?
  mitigation   String?
  closedBy     String?
  closedAt     DateTime?
  reopenedBy   String?
  reopenedAt   DateTime?
  reopenReason String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── INSPECTION READINESS ──

model Inspection {
  id             String    @id @default(cuid())
  tenantId       String
  title          String
  siteName       String
  agency         String
  type           String
  status         String    @default("planning")
  expectedDate   DateTime?
  startDate      DateTime?
  endDate        DateTime?
  inspectionLead String?
  notes          String?
  linkedFDA483Id String?
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actions         ReadinessAction[]
  simulations     Simulation[]
  readinessCards  ReadinessCard[]
  trainingRecords TrainingRecord[]
}

model ReadinessAction {
  id           String    @id @default(cuid())
  inspectionId String
  title        String
  lane         String
  bucket       String
  priority     String    @default("Medium")
  status       String    @default("Not Started")
  owner        String?
  dueDate      DateTime?
  completedBy  String?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
}

model Simulation {
  id           String    @id @default(cuid())
  inspectionId String
  title        String
  type         String
  duration     Int?
  scheduledAt  DateTime?
  participants String?
  status       String    @default("Scheduled")
  score        Int?
  notes        String?
  createdBy    String
  createdAt    DateTime  @default(now())

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
}

// ── AUDIT TRAIL ──

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  userName    String
  userRole    String?
  module      String
  action      String
  recordId    String?
  recordTitle String?
  oldValue    String?
  newValue    String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── READINESS — extended (cards / playbooks / training) ──

model ReadinessCard {
  id           String    @id @default(cuid())
  inspectionId String
  title        String
  description  String?
  category     String
  status       String    @default("not_started")
  priority     String    @default("medium")
  owner        String?
  dueDate      DateTime?
  completedBy  String?
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
}

model Playbook {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  type        String
  description String?
  content     String
  category    String   @default("general")
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TrainingRecord {
  id           String    @id @default(cuid())
  tenantId     String
  inspectionId String?
  userId       String
  userName     String
  userRole     String
  module       String
  status       String    @default("pending")
  completedAt  DateTime?
  score        Int?
  notes        String?
  createdAt    DateTime  @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inspection Inspection? @relation(fields: [inspectionId], references: [id])
}

// ── EVIDENCE COLLECTION (CAPA substage 3.2) ──
// Structured evidence collection during CAPA investigation per the GxP
// reference: 21 CFR 820.100(a)(2), 21 CFR 211.192, ICH Q10 §3.2.2,
// EU GMP Ch.1 §1.4(xiv), 21 CFR Part 11. Designed to satisfy ALCOA+.

// EvidenceItem.category — allowed values:
//   BATCH_RECORDS, TRAINING_RECORDS, EQUIPMENT_LOGS, ENVIRONMENTAL_DATA,
//   DEVIATION_HISTORY, WITNESS_INTERVIEWS, SUPPLIER_DATA
// EvidenceItem.status — allowed values:
//   PENDING, IN_PROGRESS, COMPLETE, NOT_APPLICABLE
// (No native enums: SQLite + Prisma uses string fields with Zod runtime
// validation — same pattern as CAPA.risk, Finding.severity, etc.)
model EvidenceItem {
  id                String   @id @default(cuid())
  capaId            String
  category          String
  status            String   @default("PENDING")
  notes             String?

  // Wave 3 e-sig lock placeholder (unused in v1; schema-stable for future).
  // When set, all mutations on this EvidenceItem and its files are rejected.
  lockedAt          DateTime?
  lockedBy          String?
  lockedSignatureId String?

  createdBy         String
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  capa              CAPA                  @relation(fields: [capaId], references: [id], onDelete: Cascade)
  files             EvidenceFile[]
  noteVersions      EvidenceNoteVersion[]

  @@unique([capaId, category])
  @@index([capaId])
}

// EvidenceNoteVersion — immutable historical snapshots of EvidenceItem.notes.
// Inserted (never updated) on every notes change so the prior value is
// preserved per ALCOA+ Original. statusAtTime captures the EvidenceItem.status
// at the moment the snapshot was taken.
model EvidenceNoteVersion {
  id              String   @id @default(cuid())
  evidenceItemId  String
  notes           String
  statusAtTime    String
  createdBy       String
  createdAt       DateTime @default(now())

  evidenceItem    EvidenceItem @relation(fields: [evidenceItemId], references: [id], onDelete: Cascade)

  @@index([evidenceItemId])
}

// EvidenceFile — soft-delete only per Part 11 immutability. The actual file
// on disk is preserved per ALCOA+ Enduring; deletion is metadata-only via
// (deletedAt, deletedBy, deletionReason). retainUntil is enforced server-side
// — uploads default to +7 years (conservative baseline for "≥5 years post
// product expiry" per the PDF substage 8.4 spec).
model EvidenceFile {
  id                String   @id @default(cuid())
  evidenceItemId    String
  fileName          String
  originalFileName  String
  fileSize          Int
  fileType          String
  fileExtension     String
  fileUrl           String
  contentHashSha256 String
  retainUntil       DateTime

  // Soft delete metadata
  deletedAt         DateTime?
  deletedBy         String?
  deletionReason    String?

  uploadedBy        String
  createdAt         DateTime @default(now())

  evidenceItem      EvidenceItem @relation(fields: [evidenceItemId], references: [id], onDelete: Cascade)

  @@index([evidenceItemId])
  @@index([deletedAt])
}

// ── EMAIL OTP (MFA) ──
// No FK: identifier resolves against either Tenant.email (super_admin / customer_admin)
// or User.email scoped by tenantId — a single FK can't model both. The composite
// (identifier, tenantId) lookup is sufficient; tenantId is null for Tenant-row
// matches and set for User-row matches.
model EmailOTP {
  id          String    @id @default(cuid())
  identifier  String
  tenantId    String?
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([identifier, tenantId])
  @@index([expiresAt])
}
