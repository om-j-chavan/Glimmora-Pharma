# Glimmora Pharma — environment variables template
#
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Both `.env` and `.env.local` are gitignored.
#
# In production, set these in Vercel → Project → Settings → Environment Variables.

# ─── API base (public, exposed to browser) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ─── Neon Postgres ──────────────────────────────────────────────────────
# Get these from Vercel Storage tab (auto-injected when you connect Neon)
# or from the Neon console connection details page.
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?channel_binding=require&sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# ─── NextAuth (in-app authentication) ───────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=replace-with-a-32-byte-base64-secret
NEXTAUTH_URL=http://localhost:3000

# ─── Keycloak OIDC (optional — only set if you run a Keycloak realm) ───
# KEYCLOAK_CLIENT_ID=
# KEYCLOAK_CLIENT_SECRET=
# KEYCLOAK_ISSUER=https://your-keycloak-host/realms/glimmora
